{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Strategy Lab Batch Request",
  "type": "object",
  "required": [
    "request_id",
    "created_at",
    "purpose",
    "strategy_names",
    "symbols",
    "dataset_name",
    "max_experiments",
    "shard_count",
    "safe_for_public_worker"
  ],
  "properties": {
    "request_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "purpose": { "type": "string" },
    "strategy_names": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "dataset_name": { "type": "string" },
    "max_experiments": { "type": "integer", "minimum": 1 },
    "shard_count": { "type": "integer", "minimum": 1 },
    "safe_for_public_worker": { "type": "boolean" }
  },
  "additionalProperties": false
}

