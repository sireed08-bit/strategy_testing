{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Strategy Lab Experiment Record",
  "type": "object",
  "required": [
    "experiment_id",
    "fingerprint",
    "created_at",
    "strategy",
    "dataset",
    "metrics",
    "score",
    "grade",
    "conclusion"
  ],
  "properties": {
    "experiment_id": { "type": "string" },
    "fingerprint": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "strategy": {
      "type": "object",
      "required": ["family", "name", "hypothesis", "rules", "parameters"],
      "properties": {
        "family": { "type": "string" },
        "name": { "type": "string" },
        "hypothesis": { "type": "string" },
        "rules": { "type": "object" },
        "parameters": { "type": "object" },
        "risk_model": { "type": "object" }
      },
      "additionalProperties": true
    },
    "dataset": {
      "type": "object",
      "required": ["name", "symbols", "timeframe", "start", "end"],
      "properties": {
        "name": { "type": "string" },
        "symbols": { "type": "array", "items": { "type": "string" } },
        "timeframe": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" }
      },
      "additionalProperties": true
    },
    "metrics": { "type": "object" },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "grade": {
      "type": "string",
      "enum": ["reject", "watch", "promising", "candidate"]
    },
    "conclusion": { "type": "string" },
    "weaknesses": { "type": "array", "items": { "type": "string" } },
    "next_action": { "type": "string" },
    "revisit": {
      "type": "object",
      "properties": {
        "allowed": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

